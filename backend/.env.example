# =============================================================================
# Reconny Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment
# cp .env.example .env

# =============================================================================
# Application
# =============================================================================
APP_NAME=Reconny
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# =============================================================================
# API
# =============================================================================
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://reconny:reconny123@localhost:5432/reconny
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# =============================================================================
# Celery (Task Queue)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_TIME_LIMIT=7200
CELERY_WORKER_MAX_TASKS_PER_CHILD=100

# =============================================================================
# Authentication & Security
# =============================================================================
SECRET_KEY=y0ur-v3ry-s3cr3t-k3y-here-ch4nge-in-pr0duct10n
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# =============================================================================
# OpenAI / AI
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
AI_MODEL=gpt-4o
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=4096
AI_TIMEOUT=120

# =============================================================================
# Tool Paths (Security Tools)
# =============================================================================
SUBFINDER_PATH=/usr/local/bin/subfinder
HTTPX_PATH=/usr/local/bin/httpx
KATANA_PATH=/usr/local/bin/katana
NUCLEI_PATH=/usr/local/bin/nuclei
GAU_PATH=/usr/local/bin/gau

# =============================================================================
# Storage
# =============================================================================
STORAGE_PATH=./storage/jobs
MAX_STORAGE_PER_JOB_GB=10
JOB_RETENTION_DAYS=30

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
MAX_CONCURRENT_SCANS_PER_USER=3
SCAN_RATE_LIMIT_PER_HOUR=10

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/reconny.log

# =============================================================================
# Security
# =============================================================================
ALLOWED_DOMAINS=*
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
TRUSTED_HOSTS=localhost,127.0.0.1

# =============================================================================
# Monitoring
# =============================================================================
ENABLE_METRICS=true
METRICS_PORT=9090